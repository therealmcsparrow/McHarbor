{
  "slug": "dozzle",
  "name": "Dozzle",
  "description": "Realtime log viewer for Docker containers with a web-based interface.",
  "category": "Development",
  "image": "amir20/dozzle:latest",
  "logo": "https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/dozzle.png",
  "website": "https://dozzle.dev",
  "docsUrl": "https://dozzle.dev/guide/getting-started",
  "ports": [
    {
      "host": 9999,
      "container": 8080,
      "protocol": "tcp"
    }
  ],
  "volumes": [
    {
      "host": "/var/run/docker.sock",
      "container": "/var/run/docker.sock",
      "readOnly": true
    }
  ],
  "envVars": [],
  "version": "latest"
}
