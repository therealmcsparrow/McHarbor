{
  "slug": "sonarr",
  "name": "Sonarr",
  "description": "Automatic TV show downloading and management for Usenet and BitTorrent.",
  "category": "Media",
  "image": "lscr.io/linuxserver/sonarr:latest",
  "logo": "https://raw.githubusercontent.com/linuxserver/docker-templates/master/linuxserver.io/img/sonarr-icon.png",
  "website": "https://sonarr.tv",
  "docsUrl": "https://wiki.servarr.com/sonarr",
  "ports": [
    {
      "host": 8989,
      "container": 8989,
      "protocol": "tcp"
    }
  ],
  "volumes": [
    {
      "host": "/opt/appdata/sonarr/config",
      "container": "/config"
    },
    {
      "host": "/opt/appdata/sonarr/downloads",
      "container": "/downloads"
    },
    {
      "host": "/opt/appdata/sonarr/tv",
      "container": "/tv"
    }
  ],
  "envVars": [
    {
      "key": "PUID",
      "default": "1000",
      "description": "User ID"
    },
    {
      "key": "PGID",
      "default": "1000",
      "description": "Group ID"
    },
    {
      "key": "TZ",
      "default": "America/New_York",
      "description": "Timezone"
    }
  ],
  "version": "latest"
}
