{
  "slug": "crowdsec",
  "name": "CrowdSec",
  "description": "Collaborative security engine that parses logs and detects attacks.",
  "category": "Security",
  "image": "crowdsecurity/crowdsec:latest",
  "logo": "https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/crowdsec.png",
  "website": "https://www.crowdsec.net",
  "docsUrl": "https://docs.crowdsec.net",
  "ports": [
    {
      "host": 8080,
      "container": 8080,
      "protocol": "tcp"
    },
    {
      "host": 6060,
      "container": 6060,
      "protocol": "tcp"
    }
  ],
  "volumes": [
    {
      "host": "/opt/appdata/crowdsec/config",
      "container": "/etc/crowdsec"
    },
    {
      "host": "/opt/appdata/crowdsec/data",
      "container": "/var/lib/crowdsec/data"
    }
  ],
  "envVars": [],
  "version": "latest"
}
