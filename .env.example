# App
MCHARBOR_PORT=5173
MCHARBOR_HOST=0.0.0.0
MCHARBOR_SECRET=           # Session encryption key (auto-generated if empty)
MCHARBOR_IMAGE=ghcr.io/therealmcsparrow/mcharbor
MCHARBOR_TAG=1.1.20-dev

# Database
DATABASE_PATH=./data/MCHARBOR.db  # SQLite path (default)

# Docker
DOCKER_HOST=unix:///var/run/docker.sock  # Default Docker socket
DOCKER_TLS_VERIFY=         # Enable TLS (0 or 1)
DOCKER_CERT_PATH=          # TLS certificate directory
MCHARBOR_AGENT_IMAGE=ghcr.io/therealmcsparrow/mcharbor-agent
MCHARBOR_AGENT_TAG=1.1.20-dev
MCHARBOR_AGENT_DOCKER_HOST=unix:///var/run/docker.sock
MCHARBOR_AGENT_LOG_LEVEL=info
MCHARBOR_AGENT_INSECURE=false
MCHARBOR_URL=              # Required only when running the optional agent profile
MCHARBOR_AGENT_TOKEN=      # Required only when running the optional agent profile

# Encryption
ENCRYPTION_KEY=            # AES-256-GCM key (auto-generated if empty)

# Auth
AUTH_DISABLE=false          # Disable auth (dev only)

# Notifications (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
WEBHOOK_URL=
